# Render environment variables — set these in Render dashboard
# Dashboard → your service → Environment → Environment Variables

# REQUIRED — Telegram bot token from @BotFather
TELEGRAM_BOT_TOKEN=123456:ABC-DEF1234ghIkl-zyx57W2v1u123ew11

# REQUIRED — Your TokenRouter API key (this is the one from your WSL config.yaml)
CUSTOM_API_KEY=sk-xyq...

# OPTIONAL — Your TokenRouter base URL (defaults to https://api.tokenrouter.com/v1)
CUSTOM_BASE_URL=https://api.tokenrouter.com/v1

# OPTIONAL — Override model (defaults to deepseek/deepseek-v4-pro)
HERMES_MODEL=deepseek/deepseek-v4-pro

# OPTIONAL — STT for voice (free Groq tier)
GROQ_API_KEY=gsk_...

# OPTIONAL — Restrict access
# HERMES_ALLOWED_USERS=@your_telegram_username
